#include <bits/stdc++.h>
using namespace std;

int main()
{
    int num;
    cin >> num;

    int temp = num;
    int rev = 0;

    while(temp != 0)
    {
        int r = temp % 10;
        rev = rev * 10 + r;
        temp = temp / 10;
    }

    if(rev == num)
    {
        cout << "true";
    }
    else
    {
        cout << "false";
    }

    return 0;
}
